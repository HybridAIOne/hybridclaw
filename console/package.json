{
  "name": "@hybridaione/hybridclaw-console",
  "private": true,
  "version": "0.28.4",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "npm run registry:check && tsc --noEmit && vite build",
    "dev": "vite",
    "pretest:visual": "npm run build",
    "pretest:visual:update": "npm run build",
    "test": "vitest run --config vitest.config.ts",
    "test:visual": "playwright test --config playwright.config.ts",
    "test:visual:update": "playwright test --config playwright.config.ts --update-snapshots",
    "typecheck": "npm run registry:check && tsc --noEmit",
    "registry:check": "tsx ../scripts/generate-settings-registry.ts --check",
    "lint": "tsc --noEmit --noUnusedLocals --noUnusedParameters"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.18",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "5.5.0",
    "highlight.js": "11.11.1",
    "marked": "17.0.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sanitize-html": "2.17.6"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.1",
    "@vitejs/plugin-react": "5.2.0",
    "jsdom": "26.1.0",
    "typescript": "5.9.3",
    "vite": "8.0.16"
  }
}
